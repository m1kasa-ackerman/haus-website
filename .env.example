# ─── DATABASE (Neon Postgres) ───────────────────────────────────
# Get this from: https://console.neon.tech → your project → connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ─── AUTH (Auth.js / NextAuth v5) ───────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="paste-32-char-random-secret-here"
# In dev this can be http://localhost:3000. In Vercel set to your prod URL.
AUTH_URL="http://localhost:3000"

# ─── ADMIN LOGIN (for initial seed) ─────────────────────────────
# These are used by prisma/seed.ts to create the first admin record.
# After seeding you can change the password via the studio settings.
ADMIN_EMAIL="hello@hausbyhaneesha.com"
ADMIN_PASSWORD="ChangeThisOnFirstLogin!"

# ─── IMAGEKIT ───────────────────────────────────────────────────
# Get these from: https://imagekit.io/dashboard → Developer options
IMAGEKIT_PUBLIC_KEY="public_..."
IMAGEKIT_PRIVATE_KEY="private_..."
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY="public_..."
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"

# ─── RESEND (email) ─────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
# The "from" address. While verifying your own domain, use the default
# "onboarding@resend.dev" — Resend lets you send to ONE verified email
# from that address. Once your domain is verified, change to e.g.
# "Haus Design Studio <hello@hausbyhaneesha.com>".
RESEND_FROM="onboarding@resend.dev"
# Where contact-form submissions get delivered (your Gmail to start).
INQUIRY_TO_EMAIL="haneesha@gmail.com"
